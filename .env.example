LOG_LEVEL=INFO

# Telegram settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_DROP_PENDING_UPDATES=true

# TradingView credentials (optional but recommended)
TRADINGVIEW_USERNAME=
TRADINGVIEW_PASSWORD=

# Data settings
TV_INTERVAL=1d
TV_BARS=2
IHSG_SYMBOL=COMPOSITE

# Groq AI (untuk !ai dan ringkasan !news)
GROQ_API_KEY=
GROQ_MODEL=groq/compound-mini
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# Backend Savior AI (khusus !explain, tetap GLM)
BACKEND_SAVIOR_API_KEY=
BACKEND_SAVIOR_BASE_URL=https://integrate.api.nvidia.com/v1
BACKEND_SAVIOR_MODEL=z-ai/glm5
BACKEND_SAVIOR_DEBUG=true
BACKEND_SAVIOR_MAX_TOKENS=700
BACKEND_SAVIOR_TIMEOUT_CONNECT=10
BACKEND_SAVIOR_TIMEOUT_READ=45
BACKEND_SAVIOR_RETRIES=2
BACKEND_SAVIOR_RETRY_BACKOFF_SECONDS=1.2
BACKEND_SAVIOR_FALLBACK_TO_GROQ=true
BACKEND_SAVIOR_FALLBACK_MAX_TOKENS=450

# LinkedIn auto-post (!post)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_ALLOWED_CHAT_IDS=
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_TIMEOUT_CONNECT=10
LINKEDIN_TIMEOUT_READ=45
POST_SESSION_TTL_SECONDS=900
LINKEDIN_CAPTION_MAX_CHARS=3000
LINKEDIN_MAX_IMAGES=3

# MIS logbook auto-submit (!logbook)
LOGBOOK_ENABLED=true
LOGBOOK_ALLOWED_CHAT_IDS=123456789
LOGBOOK_CAS_LOGIN_URL=https://login.pens.ac.id/cas/login?service=https%3A%2F%2Fonline.mis.pens.ac.id%2Findex.php%3FLogin%3D1%26halAwal%3D1
LOGBOOK_FORM_URL=https://online.mis.pens.ac.id/mEntry_Logbook_KP1.php
LOGBOOK_CAS_USERNAME=
LOGBOOK_CAS_PASSWORD=
LOGBOOK_DEFAULT_START_TIME=08:00
LOGBOOK_DEFAULT_END_TIME=17:00
LOGBOOK_DEFAULT_RELATED=true
LOGBOOK_DEFAULT_COURSE_KEYWORD=RI042106
LOGBOOK_DEFAULT_CHECKBOX=true
LOGBOOK_TIMEOUT_CONNECT=10
LOGBOOK_TIMEOUT_READ=45
LOGBOOK_MATERIAL_MAX_CHARS=4000

# Portfolio CRUD (!porto)
PORTFOLIO_API_BASE_URL=https://docs.soqisoqi.my.id
PORTFOLIO_API_SECRET=
